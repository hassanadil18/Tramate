# ================================================================================
# TRAMATE PLATFORM - DOCKER IGNORE
# ================================================================================
# Files and directories to exclude from Docker build context
# ================================================================================

# Version control
/.git/
/.gitignore
/.gitattributes

# Environment files
/.env*
!/.env.example

# Ruby/Rails specific
/.bundle
/vendor/bundle
/node_modules/

# Credentials and keys
/config/master.key
/config/credentials/*.key
!/config/credentials/.keep

# Logs and temporary files
/log/*
!/log/.keep
/tmp/*
!/tmp/.keep
/tmp/pids/*
!/tmp/pids/.keep

# Storage (uploaded files and databases)
/storage/*
!/storage/.keep
/tmp/storage/*
!/tmp/storage/.keep
*.sqlite3
*.sqlite3-*

# Compiled assets
/app/assets/builds/*
!/app/assets/builds/.keep
/public/assets

# Dependencies
/node_modules/

# CI/CD files
/.github
/.gitlab-ci.yml
/.circleci

# Deployment files (keep in image but ignore some)
/config/deploy*.yml
/.kamal

# Development tools
/.devcontainer
/.vscode
/.idea
*.swp
*.swo
*~

# Docker files (don't include in build context)
/docker-compose*.yml
/Dockerfile*
/.dockerignore

# Documentation (keep essential docs only)
/docs/
/README.md
/LICENSE.txt

# Test files
/test/
/spec/
/coverage/

# Backup files
*.bak
*.backup
/backups/
/dumps/

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Nginx configuration (handled separately)
/nginx/

# SSL certificates (handled separately)
/ssl/

# Data directories
/data/

# Package files
*.gem
*.tar.gz
*.zip

# Editor files
*.sublime-project
*.sublime-workspace

# Temporary build files
*.pid
*.sock

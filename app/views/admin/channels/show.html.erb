<div class="admin-dashboard">
  <div class="admin-header">
    <div class="back-link">
      <%= link_to admin_channels_path do %>
        <i class="fas fa-arrow-left"></i> Back to Channels
      <% end %>
    </div>
    <h1><%= @channel.name %></h1>
    <p class="admin-subtitle">Channel Details</p>
  </div>

  <!-- Channel Stats -->
  <div class="stats-container">
    <div class="stat-card">
      <div class="stat-icon">
        <i class="fas fa-users"></i>
      </div>
      <div class="stat-info">
        <div class="stat-value"><%= @channel.user_channel_accesses.count %></div>
        <div class="stat-label">Subscribers</div>
      </div>
    </div>
    
    <div class="stat-card">
      <div class="stat-icon">
        <i class="fas fa-signal"></i>
      </div>
      <div class="stat-info">
        <div class="stat-value"><%= @channel.trade_signals.count %></div>
        <div class="stat-label">Total Signals</div>
      </div>
    </div>
    
    <div class="stat-card">
      <div class="stat-icon">
        <i class="fas fa-chart-line"></i>
      </div>
      <div class="stat-info">
        <div class="stat-value"><%= @trades.where(status: "completed").count %></div>
        <div class="stat-label">Successful Trades</div>
      </div>
    </div>
    
    <div class="stat-card">
      <div class="stat-icon">
        <i class="fas fa-dollar-sign"></i>
      </div>
      <div class="stat-info">
        <div class="stat-value">$<%= @channel.price_per_month || 0 %></div>
        <div class="stat-label">Monthly Price</div>
      </div>
    </div>
  </div>

  <!-- Channel Details -->
  <div class="dashboard-sections">
    <!-- Basic Info -->
    <div class="dashboard-section">
      <div class="section-header">
        <h2>Channel Information</h2>
        <div class="section-actions">
          <%= link_to edit_admin_channel_path(@channel), class: "btn btn-primary" do %>
            <i class="fas fa-edit"></i> Edit Channel
          <% end %>
        </div>
      </div>
      
      <div class="info-grid">
        <div class="info-item">
          <label>Channel Type</label>
          <span class="status-badge <%= @channel.channel_type.downcase %>">
            <i class="<%= @channel.channel_type == 'discord' ? 'fab fa-discord' : 'fas fa-globe' %>"></i>
            <%= @channel.channel_type.capitalize %>
          </span>
        </div>
        
        <div class="info-item">
          <label>Status</label>
          <span class="status-badge <%= @channel.status.downcase %>">
            <%= @channel.status.capitalize %>
          </span>
        </div>
        
        <div class="info-item">
          <label>Created</label>
          <span><%= @channel.created_at.strftime("%b %d, %Y") %></span>
        </div>
        
        <div class="info-item">
          <label>Last Updated</label>
          <span><%= @channel.updated_at.strftime("%b %d, %Y") %></span>
        </div>
      </div>
      
      <div class="description-box">
        <label>Description</label>
        <p><%= @channel.description.present? ? @channel.description : "No description provided" %></p>
      </div>
    </div>

    <!-- Discord Configuration (only for Discord channels) -->
    <% if @channel.channel_type == 'discord' %>
      <div class="dashboard-section">
        <div class="section-header">
          <h2><i class="fab fa-discord"></i> Discord Configuration</h2>
          <div class="section-actions">
            <% if @channel.discord_webhook_url.blank? %>
              <%= link_to setup_discord_webhook_admin_channel_path(@channel), method: :post, class: "btn btn-success" do %>
                <i class="fas fa-plus"></i> Setup Webhook
              <% end %>
            <% end %>
            <%= link_to test_discord_connection_admin_channel_path(@channel), method: :post, class: "btn btn-info" do %>
              <i class="fas fa-plug"></i> Test Connection
            <% end %>
          </div>
        </div>
        
        <!-- Required Discord Fields -->
        <div class="required-fields-grid">
          <div class="required-field-card">
            <div class="field-header">
              <span class="field-number">1</span>
              <h4>Discord Server ID</h4>
            </div>
            <div class="field-value">
              <span class="code-text"><%= @channel.discord_guild_id || 'Not set' %></span>
            </div>
            <div class="field-description">
              <i class="fas fa-server"></i> The Discord server where the channel is located
            </div>
          </div>
          
          <div class="required-field-card">
            <div class="field-header">
              <span class="field-number">2</span>
              <h4>Discord Channel ID</h4>
            </div>
            <div class="field-value">
              <span class="code-text"><%= @channel.discord_channel_id || 'Not set' %></span>
            </div>
            <div class="field-description">
              <i class="fas fa-hashtag"></i> The specific channel for trading signals
            </div>
          </div>
          
          <div class="required-field-card">
            <div class="field-header">
              <span class="field-number">3</span>
              <h4>Channel Access Role ID</h4>
            </div>
            <div class="field-value">
              <span class="code-text"><%= @channel.discord_bot_permissions || 'Not set' %></span>
            </div>
            <div class="field-description">
              <i class="fas fa-user-tag"></i> Role required to access this channel
            </div>
          </div>
        </div>

        <!-- Additional Discord Info -->
        <div class="additional-discord-info">
          <h4>Additional Information</h4>
          <div class="info-grid">
            <div class="info-item">
              <label>Webhook Status</label>
              <% if @channel.discord_webhook_url.present? %>
                <span class="status-badge active">
                  <i class="fas fa-check"></i> Configured
                </span>
              <% else %>
                <span class="status-badge inactive">
                  <i class="fas fa-times"></i> Not Set
                </span>
              <% end %>
            </div>
            
            <div class="info-item">
              <label>Invite Link</label>
              <% if @channel.discord_invite_link.present? %>
                <%= link_to @channel.discord_invite_link, @channel.discord_invite_link, target: '_blank', class: "link-text" %>
              <% else %>
                <span class="text-muted">Not set</span>
              <% end %>
            </div>
          </div>

          <% if @channel.discord_webhook_url.present? %>
            <div class="info-item full-width">
              <label>Webhook URL</label>
              <div class="webhook-url">
                <input type="text" value="<%= @channel.discord_webhook_url %>" readonly class="form-control-readonly">
                <button onclick="copyToClipboard('<%= @channel.discord_webhook_url %>')" class="btn btn-sm btn-secondary">
                  <i class="fas fa-copy"></i> Copy
                </button>
              </div>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>

    <!-- Recent Signals -->
    <div class="dashboard-section">
      <div class="section-header">
        <h2>Recent Signals</h2>
        <%= link_to "View All", admin_trades_path(channel_id: @channel.id), class: "view-all-link" %>
      </div>
      
      <div class="table-responsive">
        <% if @signals.any? %>
          <table class="admin-table">
            <thead>
              <tr>
                <th>ID</th>
                <th>Symbol</th>
                <th>Type</th>
                <th>Status</th>
                <th>Created</th>
                <th>Action</th>
              </tr>
            </thead>
            <tbody>
              <% @signals.each do |signal| %>
                <tr>
                  <td><%= signal.id %></td>
                  <td><%= signal.symbol || 'N/A' %></td>
                  <td>
                    <span class="trade-type <%= signal.signal_type&.downcase %>">
                      <%= signal.signal_type || 'N/A' %>
                    </span>
                  </td>
                  <td>
                    <span class="status-badge <%= signal.status.downcase %>">
                      <%= signal.status %>
                    </span>
                  </td>
                  <td><%= signal.created_at.strftime("%b %d, %H:%M") %></td>
                  <td>
                    <%= link_to admin_trade_path(signal), class: "action-button view" do %>
                      <i class="fas fa-eye"></i>
                    <% end %>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        <% else %>
          <div class="empty-state">
            <i class="fas fa-signal"></i>
            <p>No signals recorded yet</p>
          </div>
        <% end %>
      </div>
    </div>

    <!-- Subscribers -->
    <div class="dashboard-section">
      <div class="section-header">
        <h2>Channel Subscribers</h2>
        <%= link_to "View All", admin_users_path(channel_id: @channel.id), class: "view-all-link" %>
      </div>
      
      <div class="table-responsive">
        <% if @channel.user_channel_accesses.any? %>
          <table class="admin-table">
            <thead>
              <tr>
                <th>User</th>
                <th>Access Type</th>
                <th>Start Date</th>
                <th>End Date</th>
                <th>Status</th>
                <th>Action</th>
              </tr>
            </thead>
            <tbody>
              <% @channel.user_channel_accesses.includes(:user).order(created_at: :desc).limit(5).each do |access| %>
                <tr>
                  <td><%= access.user.email %></td>
                  <td><%= access.access_type %></td>
                  <td><%= access.access_start_date&.strftime("%b %d, %Y") || 'N/A' %></td>
                  <td><%= access.access_end_date&.strftime("%b %d, %Y") || 'N/A' %></td>
                  <td>
                    <span class="status-badge active">Active</span>
                  </td>
                  <td>
                    <%= link_to admin_user_path(access.user), class: "action-button view" do %>
                      <i class="fas fa-eye"></i>
                    <% end %>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        <% else %>
          <div class="empty-state">
            <i class="fas fa-users"></i>
            <p>No subscribers yet</p>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>

<script>
function copyToClipboard(text) {
  navigator.clipboard.writeText(text).then(function() {
    // Show success message
    const button = event.target.closest('button');
    const originalText = button.innerHTML;
    button.innerHTML = '<i class="fas fa-check"></i> Copied!';
    button.classList.add('btn-success');
    
    setTimeout(() => {
      button.innerHTML = originalText;
      button.classList.remove('btn-success');
    }, 2000);
  });
}
</script>

<style>
  .info-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 20px;
    margin-bottom: 20px;
  }
  
  .info-item {
    background: #f9f9f9;
    padding: 15px;
    border-radius: 6px;
  }

  .info-item.full-width {
    grid-column: 1 / -1;
  }
  
  .info-item label {
    display: block;
    font-size: 12px;
    color: #666;
    margin-bottom: 5px;
    text-transform: uppercase;
    font-weight: 600;
  }

  .code-text {
    font-family: 'Courier New', monospace;
    background: #fff;
    padding: 4px 8px;
    border-radius: 4px;
    font-size: 13px;
    border: 1px solid #ddd;
  }

  .webhook-url {
    display: flex;
    gap: 10px;
    align-items: center;
  }

  .webhook-url input {
    flex: 1;
    font-family: 'Courier New', monospace;
    font-size: 12px;
  }

  .form-control-readonly {
    background: #fff;
    border: 1px solid #ddd;
    padding: 8px 12px;
    border-radius: 4px;
    color: #555;
  }

  .link-text {
    color: #007bff;
    text-decoration: none;
    word-break: break-all;
  }

  .link-text:hover {
    text-decoration: underline;
  }

  .text-muted {
    color: #999;
    font-style: italic;
  }

  .empty-state {
    text-align: center;
    padding: 40px;
    color: #999;
  }

  .empty-state i {
    font-size: 48px;
    margin-bottom: 15px;
    opacity: 0.5;
  }

  .status-badge.discord {
    background: #5865f2;
    color: white;
  }

  .status-badge.active {
    background: #28a745;
    color: white;
  }

  .status-badge.inactive {
    background: #dc3545;
    color: white;
  }

  /* Required Discord Fields Styles */
  .required-fields-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 20px;
    margin-bottom: 30px;
  }

  .required-field-card {
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    color: white;
    border-radius: 12px;
    padding: 20px;
    box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
    transition: transform 0.2s ease;
  }

  .required-field-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 12px rgba(0, 0, 0, 0.15);
  }

  .field-header {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 12px;
  }

  .field-number {
    background: rgba(255, 255, 255, 0.2);
    color: white;
    width: 28px;
    height: 28px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 14px;
    font-weight: bold;
    border: 2px solid rgba(255, 255, 255, 0.3);
  }

  .field-header h4 {
    margin: 0;
    font-size: 16px;
    font-weight: 600;
  }

  .field-value {
    margin-bottom: 10px;
  }

  .field-value .code-text {
    background: rgba(255, 255, 255, 0.9);
    color: #333;
    font-weight: 600;
    padding: 8px 12px;
    font-size: 14px;
  }

  .field-description {
    font-size: 14px;
    opacity: 0.9;
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .field-description i {
    opacity: 0.8;
  }

  .additional-discord-info {
    background: #f8f9fa;
    border-radius: 8px;
    padding: 20px;
    margin-top: 20px;
  }

  .additional-discord-info h4 {
    margin: 0 0 15px 0;
    color: #495057;
    font-size: 16px;
    font-weight: 600;
  }
</style> 
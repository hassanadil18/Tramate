<!-- Admin Dashboard Index View -->
<div class="admin-dashboard">
  <div class="admin-header">
    <h1>Admin Dashboard</h1>
    <p class="admin-subtitle">System overview and management</p>
  </div>

  <!-- Overview Cards -->
  <div class="dashboard-grid">
    <!-- Users Card -->
    <div class="card">
      <div class="card-header">
        <div class="header-left">
          <span class="icon"></span>
          <h4>Total Users</h4>
        </div>
      </div>
      <div class="large-text"><%= @users_count %></div>
      <div class="status">
        <%= link_to "View All Users", admin_users_path, style: "color: #00ADB5; text-decoration: none;" %>
      </div>
    </div>

    <!-- Active Subscriptions -->
    <div class="card">
      <div class="card-header">
        <div class="header-left">
          <span class="icon"></span>
          <h4>Active Subscriptions</h4>
        </div>
      </div>
      <div class="large-text"><%= @active_subscriptions %></div>
      <div class="status">
        <%= link_to "View All Subscriptions", admin_subscriptions_path, style: "color: #00ADB5; text-decoration: none;" %>
      </div>
    </div>

    <!-- Trades Stats -->
    <div class="card">
      <div class="card-header">
        <div class="header-left">
          <span class="icon"></span>
          <h4>Total Trades</h4>
        </div>
      </div>
      <div class="large-text"><%= @total_trades %></div>
      <div class="status">
        <span class="positive"><%= @completed_trades %> completed</span> |
        <span class="negative"><%= @failed_trades %> failed</span>
      </div>
    </div>

    <!-- Success Rate -->
    <div class="card">
      <div class="card-header">
        <div class="header-left">
          <span class="icon"></span>
          <h4>Success Rate</h4>
        </div>
      </div>
      <div class="large-text"><%= @success_rate %>%</div>
      <div class="status positive">
        <%= @completed_trades %> of <%= @completed_trades + @failed_trades %> trades successful
      </div>
    </div>
  </div>

  <div style="display: flex; gap: 20px; margin-top: 20px;">
    <!-- Monthly Revenue -->
    <div class="card" style="flex: 1;">
      <div class="card-header">
        <div class="header-left">
          <span class="icon"></span>
          <h4>Monthly Revenue</h4>
        </div>
      </div>
      <div class="large-text">$<%= @revenue_this_month %></div>
      <div class="status positive">From subscription payments</div>

      <div style="margin-top: 20px;">
        <h4 style="margin-bottom: 10px;">Revenue Breakdown</h4>
        <div style="display: flex; gap: 10px; align-items: center; margin-bottom: 8px;">
          <div style="width: 12px; height: 12px; background-color: #00ADB5; border-radius: 2px;"></div>
          <span>Premium Subscriptions</span>
        </div>
        <div style="display: flex; gap: 10px; align-items: center;">
          <div style="width: 12px; height: 12px; background-color: #FF5722; border-radius: 2px;"></div>
          <span>Intermediate Subscriptions</span>
        </div>
      </div>
    </div>

    <!-- Channels Summary -->
    <div class="card" style="flex: 1;">
      <div class="card-header">
        <div class="header-left">
          <span class="icon"></span>
          <h4>Channels</h4>
        </div>
      </div>
      <div class="large-text"><%= @channels_count %></div>
      <div class="status">
        <%= link_to "Manage Channels", admin_channels_path, style: "color: #00ADB5; text-decoration: none;" %>
      </div>

      <div style="margin-top: 20px; margin-bottom: 10px;">
        <h4>Channel Activity</h4>
      </div>
      <div style="display: flex; flex-direction: column; gap: 8px;">
        <div style="background-color: #f8f9fa; padding: 10px; border-radius: 5px;">
          <strong>Most Active: </strong> Channel name with most subscribers
        </div>
        <div style="background-color: #f8f9fa; padding: 10px; border-radius: 5px;">
          <strong>Newest: </strong> Most recently added channel
        </div>
      </div>
    </div>
  </div>

  <!-- Recent Trades -->
  <div class="card" style="margin-top: 20px;">
    <div class="card-header">
      <div class="header-left">
        <span class="icon"></span>
        <h4>Recent Trades</h4>
      </div>
      <%= link_to "View All", admin_trades_path, class: "primary-btn", style: "padding: 8px 15px; font-size: 14px;" %>
    </div>
    <div class="table-container">
      <% if @recent_trades.present? %>
        <table>
          <thead>
            <tr>
              <th>ID</th>
              <th>User</th>
              <th>Coin</th>
              <th>Type</th>
              <th>Amount</th>
              <th>Status</th>
              <th>Date</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody>
            <% @recent_trades.each do |trade| %>
              <tr>
                <td><%= trade.id %></td>
                <td><%= trade.user.full_name %></td>
                <td><%= trade.coin %></td>
                <td><%= trade.order_side %></td>
                <td><%= trade.amount %></td>
                <td>
                  <% if trade.status == "completed" %>
                    <span class="badge-status badge-active">Completed</span>
                  <% elsif trade.status == "failed" %>
                    <span class="badge-status badge-inactive">Failed</span>
                  <% else %>
                    <span class="badge-status badge-pending"><%= trade.status.capitalize %></span>
                  <% end %>
                </td>
                <td><%= trade.created_at.strftime("%b %d, %H:%M") %></td>
                <td>
                  <div class="action-buttons">
                    <%= link_to admin_trade_path(trade), class: "btn-action btn-view" do %>
                      <i class="fas fa-eye"></i>
                    <% end %>
                  </div>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      <% else %>
        <p>No trades recorded yet.</p>
      <% end %>
    </div>
  </div>

  <!-- Recent Users and System Logs -->
  <div style="display: flex; gap: 20px; margin-top: 20px;">
    <!-- Recent Users -->
    <div class="card" style="flex: 1;">
      <div class="card-header">
        <div class="header-left">
          <span class="icon"></span>
          <h4>Recent Users</h4>
        </div>
      </div>
      <div class="table-container">
        <% if @recent_users.present? %>
          <table>
            <thead>
              <tr>
                <th>User</th>
                <th>Email</th>
                <th>Subscription</th>
                <th>Joined</th>
              </tr>
            </thead>
            <tbody>
              <% @recent_users.each do |user| %>
                <tr>
                  <td><%= user.full_name %></td>
                  <td><%= user.email %></td>
                  <td>
                    <% if user.subscription %>
                      <span class="badge-status badge-active"><%= user.subscription.name %></span>
                    <% else %>
                      <span class="badge-status badge-inactive">None</span>
                    <% end %>
                  </td>
                  <td><%= user.created_at.strftime("%b %d, %Y") %></td>
                </tr>
              <% end %>
            </tbody>
          </table>
        <% else %>
          <p>No users registered yet.</p>
        <% end %>
      </div>
    </div>

    <!-- System Logs -->
    <div class="card" style="flex: 1;">
      <div class="card-header">
        <div class="header-left">
          <span class="icon"></span>
          <h4>System Logs</h4>
        </div>
        <%= link_to "View All", admin_logs_path, class: "primary-btn", style: "padding: 8px 15px; font-size: 14px;" %>
      </div>
      <div class="table-container">
        <% if @recent_logs.present? %>
          <table>
            <thead>
              <tr>
                <th>Level</th>
                <th>Message</th>
                <th>Time</th>
              </tr>
            </thead>
            <tbody>
              <% @recent_logs.each do |log| %>
                <tr>
                  <td>
                    <% if log.level == "error" %>
                      <span class="badge-status badge-inactive">Error</span>
                    <% elsif log.level == "warn" %>
                      <span class="badge-status badge-pending">Warning</span>
                    <% else %>
                      <span class="badge-status badge-active">Info</span>
                    <% end %>
                  </td>
                  <td><%= log.message.truncate(40) %></td>
                  <td><%= log.created_at.strftime("%H:%M:%S") %></td>
                </tr>
              <% end %>
            </tbody>
          </table>
        <% else %>
          <p>No system logs recorded yet.</p>
        <% end %>
      </div>
    </div>
  </div>
</div>

<style>
  .admin-dashboard {
    padding: 20px;
    max-width: 1400px;
    margin: 0 auto;
  }
  
  .admin-header {
    margin-bottom: 30px;
  }
  
  .admin-header h1 {
    font-size: 28px;
    font-weight: 700;
    margin-bottom: 5px;
    color: #222831;
  }
  
  .admin-subtitle {
    color: #888;
    font-size: 14px;
  }
  
  .stats-container {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 20px;
    margin-bottom: 30px;
  }
  
  .stat-card {
    background: white;
    box-shadow: 0 4px 10px rgba(0,0,0,0.05);
    border-radius: 8px;
    padding: 20px;
    display: flex;
    align-items: center;
  }
  
  .stat-icon {
    width: 50px;
    height: 50px;
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-right: 15px;
    font-size: 20px;
    color: white;
  }
  
  .users-icon {
    background: linear-gradient(45deg, #396afc, #2948ff);
  }
  
  .channels-icon {
    background: linear-gradient(45deg, #11998e, #38ef7d);
  }
  
  .trades-icon {
    background: linear-gradient(45deg, #f12711, #f5af19);
  }
  
  .logs-icon {
    background: linear-gradient(45deg, #8e2de2, #4a00e0);
  }
  
  .stat-info {
    flex: 1;
  }
  
  .stat-value {
    font-size: 24px;
    font-weight: 700;
    color: #222831;
  }
  
  .stat-label {
    font-size: 14px;
    color: #666;
  }
  
  .stat-actions {
    margin-left: auto;
  }
  
  .admin-sections {
    display: flex;
    flex-direction: column;
    gap: 30px;
  }
  
  .admin-section {
    background: white;
    box-shadow: 0 4px 10px rgba(0,0,0,0.05);
    border-radius: 8px;
    padding: 20px;
  }
  
  .section-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 20px;
    padding-bottom: 10px;
    border-bottom: 1px solid #eee;
  }
  
  .section-header h2 {
    font-size: 18px;
    font-weight: 600;
    margin: 0;
  }
  
  .view-all {
    color: #00ADB5;
    text-decoration: none;
    font-size: 14px;
  }
  
  .table-responsive {
    overflow-x: auto;
  }
  
  .admin-table {
    width: 100%;
    border-collapse: collapse;
  }
  
  .admin-table th, 
  .admin-table td {
    padding: 12px 15px;
    text-align: left;
  }
  
  .admin-table th {
    background: #f9f9f9;
    font-weight: 500;
    color: #444;
    font-size: 14px;
  }
  
  .admin-table tbody tr {
    border-bottom: 1px solid #f2f2f2;
  }
  
  .admin-table tbody tr:hover {
    background-color: #f9fcff;
  }
  
  .status-badge {
    padding: 4px 8px;
    border-radius: 4px;
    font-size: 12px;
    font-weight: 500;
  }
  
  .status-badge.active {
    background-color: rgba(46, 213, 115, 0.15);
    color: #2ed573;
  }
  
  .status-badge.admin {
    background-color: rgba(93, 63, 211, 0.15);
    color: #5d3fd3;
  }
  
  .status-badge.completed,
  .status-badge.success {
    background-color: rgba(46, 213, 115, 0.15);
    color: #2ed573;
  }
  
  .status-badge.pending {
    background-color: rgba(255, 168, 0, 0.15);
    color: #ffa800;
  }
  
  .status-badge.failed {
    background-color: rgba(255, 71, 87, 0.15);
    color: #ff4757;
  }
  
  .trade-type {
    padding: 4px 8px;
    border-radius: 4px;
    font-size: 12px;
    font-weight: 500;
  }
  
  .trade-type.buy {
    background-color: rgba(46, 213, 115, 0.15);
    color: #2ed573;
  }
  
  .trade-type.sell {
    background-color: rgba(255, 71, 87, 0.15);
    color: #ff4757;
  }
  
  .action-link {
    color: #00ADB5;
    text-decoration: none;
    font-size: 14px;
    margin-right: 10px;
  }
  
  .btn-sm {
    padding: 5px 10px;
    font-size: 12px;
    background: #00ADB5;
    color: white;
    border: none;
    border-radius: 4px;
    text-decoration: none;
    cursor: pointer;
    display: inline-block;
  }
  
  .btn-sm:hover {
    background: #008c94;
  }
  
  @media (max-width: 768px) {
    .stats-container {
      grid-template-columns: 1fr;
    }
  }
  
  /* Dashboard specific styles */
  .quick-actions {
    background: white;
    border-radius: 8px;
    padding: 20px;
    margin-bottom: 20px;
    box-shadow: 0 2px 5px rgba(0,0,0,0.05);
  }
  
  .quick-actions h2 {
    font-size: 18px;
    font-weight: 600;
    margin-bottom: 20px;
    color: #333;
  }
  
  .action-buttons {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 15px;
  }
  
  .action-button {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 15px;
    background: #f9f9f9;
    border-radius: 6px;
    color: #333;
    text-decoration: none;
    transition: all 0.2s ease;
  }
  
  .action-button:hover {
    background: #f0f0f0;
    transform: translateY(-2px);
  }
  
  .action-button i {
    font-size: 20px;
    color: #0066ff;
  }
  
  .dashboard-sections {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(400px, 1fr));
    gap: 20px;
  }
  
  .dashboard-section {
    background: white;
    border-radius: 8px;
    padding: 20px;
    box-shadow: 0 2px 5px rgba(0,0,0,0.05);
  }
  
  .section-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 20px;
  }
  
  .section-header h2 {
    font-size: 18px;
    font-weight: 600;
    color: #333;
  }
  
  .view-all-link {
    color: #0066ff;
    text-decoration: none;
    font-size: 14px;
  }
  
  .view-all-link:hover {
    text-decoration: underline;
  }
  
  /* Responsive adjustments */
  @media (max-width: 768px) {
    .dashboard-sections {
      grid-template-columns: 1fr;
    }
    
    .action-buttons {
      grid-template-columns: 1fr;
    }
  }
</style>
<h1>Admin::Notifications#index</h1>
<p>Find me in app/views/admin/notifications/index.html.erb</p>

<div class="card">
  <div class="card-header">
    <div class="header-left">
      <div class="icon"></div>
      <h4>Notifications</h4>
    </div>
    <% if @notifications.unread.any? %>
      <%= button_to "Mark All as Read", mark_all_as_read_admin_notifications_path, method: :post, class: "primary-btn", data: { turbo: false } %>
    <% end %>
  </div>

  <div class="table-container">
    <% if @notifications.any? %>
      <table>
        <thead>
          <tr>
            <th>Message</th>
            <th>Type</th>
            <th>Date</th>
            <th>Status</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody>
          <% @notifications.each do |notification| %>
            <tr class="<%= notification.read ? '' : 'bg-light' %>">
              <td><%= notification.message %></td>
              <td>
                <span class="badge-status <%= notification.notification_type == 'system' ? 'badge-active' : 'badge-pending' %>">
                  <%= notification.notification_type.capitalize %>
                </span>
              </td>
              <td><%= notification.created_at.strftime("%b %d, %Y at %I:%M %p") %></td>
              <td>
                <% if notification.read %>
                  <span class="badge-status badge-inactive">Read</span>
                <% else %>
                  <span class="badge-status badge-active">Unread</span>
                <% end %>
              </td>
              <td class="action-buttons">
                <% unless notification.read %>
                  <%= button_to "Mark as Read", mark_as_read_admin_notification_path(notification), method: :post, class: "btn-action btn-view", data: { turbo: false } %>
                <% end %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    <% else %>
      <p class="text-center p-4">No notifications found.</p>
    <% end %>
  </div>
</div>

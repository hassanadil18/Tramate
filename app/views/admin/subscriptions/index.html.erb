<div class="container mt-4">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h1>Subscription Plans</h1>
    <div>
      <%= link_to "Export CSV", admin_subscriptions_path(format: :csv), class: "btn btn-secondary me-2" %>
      <%= link_to "Create New Plan", new_admin_subscription_path, class: "btn btn-primary" %>
    </div>
  </div>

  <% if flash[:notice] %>
    <div class="alert alert-success"><%= flash[:notice] %></div>
  <% end %>
  
  <% if flash[:alert] %>
    <div class="alert alert-danger"><%= flash[:alert] %></div>
  <% end %>

  <div class="table-responsive">
    <table class="table table-striped">
      <thead>
        <tr>
          <th>ID</th>
          <th>Name</th>
          <th>Price</th>
          <th>Trade Limit</th>
          <th>User</th>
          <th>Status</th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody>
        <% @subscriptions.each do |subscription| %>
          <tr>
            <td><%= subscription.id %></td>
            <td><%= subscription.name %></td>
            <td>$<%= subscription.price %></td>
            <td>
              <% if subscription.trade_limit.nil? %>
                Unlimited
              <% else %>
                <%= subscription.trade_limit %>
              <% end %>
            </td>
            <td>
              <% if subscription.user %>
                <%= link_to subscription.user.email, admin_user_path(subscription.user) %>
              <% else %>
                <span class="badge bg-info">Template Plan</span>
              <% end %>
            </td>
            <td>
              <% if subscription.status.present? %>
                <span class="badge bg-<%= subscription.status == 'active' ? 'success' : 'danger' %>">
                  <%= subscription.status.capitalize %>
                </span>
              <% else %>
                <span class="badge bg-secondary">N/A</span>
              <% end %>
            </td>
            <td>
              <%= link_to "View", admin_subscription_path(subscription), class: "btn btn-sm btn-info" %>
              
              <% if subscription.user.nil? %>
                <%= link_to "Edit", edit_admin_subscription_path(subscription), class: "btn btn-sm btn-warning" %>
                <%= button_to "Delete", admin_subscription_path(subscription), 
                    method: :delete, 
                    form: { data: { turbo_confirm: "Are you sure you want to delete this plan?" } }, 
                    class: "btn btn-sm btn-danger" %>
              <% end %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div> 
<div class="container mt-4">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h1>Subscription Details</h1>
    <%= link_to "Back to Subscriptions", admin_subscriptions_path, class: "btn btn-secondary" %>
  </div>

  <% if flash[:notice] %>
    <div class="alert alert-success"><%= flash[:notice] %></div>
  <% end %>
  
  <div class="card">
    <div class="card-header">
      <h3><%= @subscription.name %></h3>
    </div>
    <div class="card-body">
      <div class="row">
        <div class="col-md-6">
          <p><strong>ID:</strong> <%= @subscription.id %></p>
          <p><strong>Price:</strong> $<%= @subscription.price %></p>
          <p><strong>Trade Limit:</strong> 
            <% if @subscription.trade_limit.nil? %>
              Unlimited
            <% else %>
              <%= @subscription.trade_limit %>
            <% end %>
          </p>
          <p><strong>Status:</strong> 
            <% if @subscription.status.present? %>
              <span class="badge bg-<%= @subscription.status == 'active' ? 'success' : 'danger' %>">
                <%= @subscription.status.capitalize %>
              </span>
            <% else %>
              <span class="badge bg-secondary">N/A</span>
            <% end %>
          </p>
        </div>
        <div class="col-md-6">
          <p><strong>Description:</strong> <%= @subscription.description %></p>
          <p><strong>Created At:</strong> <%= @subscription.created_at.strftime("%B %d, %Y") %></p>
          <p><strong>Updated At:</strong> <%= @subscription.updated_at.strftime("%B %d, %Y") %></p>
          <p><strong>Assigned To:</strong> 
            <% if @subscription.user %>
              <%= link_to @subscription.user.email, admin_user_path(@subscription.user) %>
            <% else %>
              <span class="badge bg-info">Template Plan</span>
            <% end %>
          </p>
        </div>
      </div>
    </div>
    <div class="card-footer">
      <% if @subscription.user.nil? %>
        <%= link_to "Edit", edit_admin_subscription_path(@subscription), class: "btn btn-warning" %>
        <%= button_to "Delete", admin_subscription_path(@subscription), 
            method: :delete, 
            form: { data: { turbo_confirm: "Are you sure you want to delete this plan?" } }, 
            class: "btn btn-danger" %>
      <% end %>
    </div>
  </div>
</div> 
<div class="api-credentials-container">
  <div class="api-credentials-header">
    <h1>Your Binance API Connections</h1>
    <p class="api-credentials-subtitle">Connect your Binance account to enable automated trading based on signals.</p>
  </div>

<% if @api_credentials.any? %>
    <!-- Existing API Credentials -->
    <div class="credentials-list">
        <% @api_credentials.each do |credential| %>
        <div class="credential-card">
          <div class="credential-header">
            <div class="credential-info">
              <h3><%= credential.label || "Binance API Connection" %></h3>
              <p class="credential-platform">
                <i class="fas fa-exchange-alt"></i>
                <%= credential.platform.titleize %>
              </p>
            </div>
            <div class="credential-status">
              <% if credential.active? %>
                <span class="status-badge active">
                  <i class="fas fa-check-circle"></i> Active
                </span>
              <% else %>
                <span class="status-badge inactive">
                  <i class="fas fa-times-circle"></i> Inactive
                </span>
              <% end %>
            </div>
          </div>

          <div class="credential-details">
            <div class="detail-grid">
              <div class="detail-item">
                <span class="detail-label">API Key:</span>
                <span class="detail-value api-key">
                  <%= credential.api_key[0..8] %>...
                </span>
              </div>
              
              <div class="detail-item">
                <span class="detail-label">Connected:</span>
                <span class="detail-value">
                  <%= credential.created_at.strftime("%b %d, %Y") %>
                </span>
              </div>
              
              <% if credential.validated_at %>
                <div class="detail-item">
                  <span class="detail-label">Last Validated:</span>
                  <span class="detail-value">
                    <%= credential.validated_at.strftime("%b %d, %Y at %H:%M") %>
                  </span>
                </div>
              <% end %>
              
              <% if credential.account_type %>
                <div class="detail-item">
                  <span class="detail-label">Account Type:</span>
                  <span class="detail-value">
                    <%= credential.account_type.titleize %>
                  </span>
                </div>
              <% end %>
            </div>

            <% if credential.can_trade || credential.can_withdraw %>
              <div class="permissions">
                <h4>Permissions:</h4>
                <div class="permission-list">
                  <% if credential.can_trade %>
                    <span class="permission-badge allowed">
                      <i class="fas fa-check"></i> Trading
                    </span>
                  <% end %>
                  <% if credential.can_withdraw %>
                    <span class="permission-badge warning">
                      <i class="fas fa-exclamation-triangle"></i> Withdrawal
                    </span>
                  <% end %>
                </div>
              </div>
            <% end %>
          </div>

          <div class="credential-actions">
            <%= link_to edit_api_credential_path(credential), class: "btn btn-outline-primary" do %>
              <i class="fas fa-edit"></i> Edit
            <% end %>
            
            <%= button_to validate_api_credential_path(credential), 
                          method: :post,
                          class: "btn btn-info",
                          form: { style: "display: inline;" } do %>
              <i class="fas fa-check-double"></i> Validate
            <% end %>
            
            <% unless credential.active? %>
              <%= link_to api_credential_path(credential), method: :patch, 
                          params: { api_credential: { active: true } },
                          class: "btn btn-success" do %>
                <i class="fas fa-play"></i> Activate
              <% end %>
            <% end %>
            
            <%= link_to api_credential_path(credential), 
                    method: :delete, 
                        data: { 
                          confirm: "Are you sure you want to remove this API connection? This will disable automated trading." 
                        }, 
                        class: "btn btn-outline-danger" do %>
              <i class="fas fa-trash"></i> Remove
            <% end %>
          </div>
        </div>
      <% end %>
    </div>

    <!-- Add Another Connection -->
    <div class="add-connection-section">
      <div class="add-connection-card">
        <h3>Add Another Connection</h3>
        <p>You can add multiple API connections for different trading strategies.</p>
        <%= link_to new_api_credential_path, class: "btn btn-primary" do %>
          <i class="fas fa-plus"></i> Add New Binance Connection
        <% end %>
      </div>
  </div>

<% else %>
    <!-- No Credentials Yet -->
    <div class="empty-state">
      <div class="empty-icon">🔑</div>
      <h3>No API connections yet</h3>
      <p>Add your first Binance API connection to enable automated trading.</p>
      <%= link_to new_api_credential_path, class: "btn btn-primary btn-lg" do %>
        <i class="fas fa-plus"></i> Add New Binance Connection
      <% end %>
  </div>
<% end %>

  <!-- Information Section -->
  <div class="info-section">
    <div class="info-card">
      <h3>About Binance API Integration</h3>
  <p>
    Tramate uses your Binance API credentials to execute trades on your behalf based on signals.
    Your API credentials are encrypted securely and never shared with third parties.
  </p>
      
      <div class="security-notice">
        <div class="notice-icon">
          <i class="fas fa-shield-alt"></i>
        </div>
        <div class="notice-content">
          <h4>Security Recommendation</h4>
          <p>For your security, we recommend creating API keys with <strong>trading permissions only</strong> (no withdrawal permissions).</p>
        </div>
      </div>
    </div>
  </div>
</div>


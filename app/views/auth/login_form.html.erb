<% content_for :title, "Login" %>

<div class="auth-container">
  <div class="auth-image">
    <h2>Welcome Back!</h2>
    <p>Log in to access your Tramate dashboard and manage your automated trading activities.</p>
  </div>
  
  <div class="auth-form">
    <div class="auth-logo">
      <span class="logo-text">Tramate.</span>
    </div>
    
    <h1 class="auth-title">Log in to your account</h1>
    
    <% if flash[:notice] %>
      <div class="flash flash-notice"><%= flash[:notice] %></div>
    <% end %>
    
    <% if flash[:alert] %>
      <div class="flash flash-alert"><%= flash[:alert] %></div>
    <% end %>
    
    <%= form_with url: auth_login_path, method: :post, local: true do |f| %>
      <div class="form-group">
        <%= f.label :email, "Email Address", class: "form-label" %>
        <%= f.email_field :email, class: "form-control", required: true, autofocus: true %>
      </div>
      
      <div class="form-group">
        <%= f.label :password, "Password", class: "form-label" %>
        <%= f.password_field :password, class: "form-control", required: true %>
      </div>
      
      <%= f.submit "Log In", class: "auth-btn" %>
    <% end %>
    
    <p class="auth-text">
      Don't have an account? <%= link_to "Register now", auth_register_form_path, class: "auth-link" %>
    </p>
    
    <p class="auth-text">
      <%= link_to "Back to Home", root_path %>
    </p>
  </div>
</div> 
<div class="registration-page">
<div class="registration-container">
  <div class="registration-content">
      <h1 class="registration-title">Create your account</h1>
      <p class="registration-subtitle">Join Tramate to automate your crypto trading</p>

      <% if flash[:alert] %>
        <div class="alert alert-danger">
          <%= flash[:alert] %>
    </div>
      <% end %>

      <%= form_with url: auth_register_path, method: :post, local: true, class: "registration-form" do |form| %>
          <div class="form-group">
          <label for="full_name">Full Name</label>
          <input type="text" name="full_name" id="full_name" class="form-control" required value="<%= params[:full_name] %>">
          </div>
          
          <div class="form-group">
          <label for="email">Email</label>
          <input type="email" name="email" id="email" class="form-control" required value="<%= params[:email] %>">
          </div>
          
          <div class="form-group">
          <label for="password">Password</label>
          <input type="password" name="password" id="password" class="form-control" required>
          <small class="form-text text-muted">At least 6 characters</small>
          </div>
          
          <div class="form-group">
          <label for="password_confirmation">Confirm Password</label>
          <input type="password" name="password_confirmation" id="password_confirmation" class="form-control" required>
          </div>
          
          <div class="form-group form-check">
          <input type="checkbox" name="terms_of_service" id="terms_of_service" class="form-check-input" required>
          <label for="terms_of_service" class="form-check-label">
              I agree to Tramate's <a href="#" target="_blank">Terms of Service</a> and <a href="#" target="_blank">Privacy Policy</a>
            </label>
        </div>
        
        <div class="form-actions">
          <%= form.submit "Start Registration Process", class: "btn btn-primary btn-block" %>
        </div>
      <% end %>

      <div class="login-link">
        <p>Already have an account? <%= link_to "Sign in", auth_login_form_path %></p>
      </div>

      <div class="features-preview">
        <h3>What you'll get:</h3>
        <ul>
          <li><i class="fas fa-check"></i> Discord signal integration</li>
          <li><i class="fas fa-check"></i> Automated Binance trading</li>
          <li><i class="fas fa-check"></i> Real-time trade monitoring</li>
          <li><i class="fas fa-check"></i> Professional trading tools</li>
        </ul>
      </div>
    </div>
  </div>
</div>

<style>
.registration-page {
  padding: 40px 20px;
  background-color: #f5f5f5;
  min-height: calc(100vh - 160px);
}

.registration-container {
  display: flex;
  justify-content: center;
  align-items: center;
}

.registration-content {
  width: 100%;
  max-width: 500px;
  background-color: #fff;
  border-radius: 8px;
  box-shadow: 0 2px 15px rgba(0, 0, 0, 0.1);
  padding: 40px;
}

.registration-title {
  text-align: center;
  font-size: 28px;
  font-weight: 700;
  color: #222831;
  margin-bottom: 5px;
}

.registration-subtitle {
  text-align: center;
  color: #666;
  margin-bottom: 30px;
}

.registration-form {
  margin-bottom: 30px;
}

.form-group {
  margin-bottom: 20px;
}

.form-group label {
  display: block;
  font-weight: 600;
  margin-bottom: 8px;
  color: #222831;
}

.form-control {
  width: 100%;
  height: 50px;
  padding: 12px 15px;
  font-size: 16px;
  border: 2px solid #e1e8ed;
  border-radius: 8px;
  background-color: #fff;
  transition: all 0.3s;
}

.form-control:focus {
  outline: none;
  border-color: #0FA958;
  box-shadow: 0 0 0 3px rgba(15, 169, 88, 0.1);
}

.form-text {
  font-size: 14px;
  color: #666;
  margin-top: 8px;
}

.form-check {
  display: flex;
  align-items: flex-start;
  gap: 10px;
}

.form-check-input {
  width: auto;
  height: auto;
  margin: 0;
  flex-shrink: 0;
  margin-top: 3px;
}

.form-check-label {
  font-size: 14px;
  color: #666;
  line-height: 1.5;
}

.btn {
  padding: 12px 24px;
  border-radius: 8px;
  text-decoration: none;
  font-weight: 500;
  border: 2px solid;
  cursor: pointer;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  transition: all 0.3s;
  font-size: 16px;
}

.btn-primary {
  background: #0FA958;
  color: white;
  border-color: #0FA958;
}

.btn-primary:hover {
  background: #0d8a49;
  border-color: #0d8a49;
  text-decoration: none;
  color: white;
}

.btn-block {
  width: 100%;
}

.login-link {
  text-align: center;
  margin-bottom: 30px;
}

.login-link a {
  color: #0FA958;
  text-decoration: none;
  font-weight: 500;
}

.login-link a:hover {
  text-decoration: underline;
}

.features-preview {
  background: #f8f9fa;
  border-radius: 8px;
  padding: 20px;
}

.features-preview h3 {
  color: #222831;
  margin-bottom: 15px;
  font-size: 18px;
}

.features-preview ul {
  list-style: none;
  padding: 0;
  margin: 0;
}

.features-preview li {
  display: flex;
  align-items: center;
  gap: 10px;
  margin-bottom: 10px;
  color: #666;
}

.features-preview li i {
  color: #0FA958;
  font-size: 14px;
}

.alert {
  padding: 15px;
  border-radius: 8px;
  margin-bottom: 20px;
}

.alert-danger {
  background-color: #f8d7da;
  color: #721c24;
  border: 1px solid #f5c6cb;
}

@media (max-width: 768px) {
  .registration-page {
    padding: 20px 15px;
  }
  
  .registration-content {
    padding: 30px 20px;
  }
}
</style>
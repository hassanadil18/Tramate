<% content_for :title, "Register" %>

<div class="auth-container">
  <div class="auth-image">
    <h2>Start Your Trading Journey</h2>
    <p>Register to access Tramate's powerful automated trading platform. Connect your exchange accounts and start trading with professional signals.</p>
  </div>
  
  <div class="auth-form">
    <div class="auth-logo">
      <span class="logo-text">Tramate.</span>
    </div>
    
    <h1 class="auth-title">Create an account</h1>
    
    <% if flash[:notice] %>
      <div class="flash flash-notice"><%= flash[:notice] %></div>
    <% end %>
    
    <% if flash[:alert] %>
      <div class="flash flash-alert"><%= flash[:alert] %></div>
    <% end %>
    
    <%= form_with model: @user, url: auth_register_path, method: :post, local: true do |f| %>
      <div class="form-row">
        <div class="form-group">
          <%= f.label :first_name, "First Name", class: "form-label" %>
          <%= f.text_field :first_name, class: "form-control", required: true, autofocus: true %>
          <% if @user.errors[:first_name].any? %>
            <span class="field-error"><%= @user.errors[:first_name].first %></span>
          <% end %>
        </div>
        
        <div class="form-group">
          <%= f.label :last_name, "Last Name", class: "form-label" %>
          <%= f.text_field :last_name, class: "form-control", required: true %>
          <% if @user.errors[:last_name].any? %>
            <span class="field-error"><%= @user.errors[:last_name].first %></span>
          <% end %>
        </div>
      </div>
      
      <div class="form-group">
        <%= f.label :email, "Email Address", class: "form-label" %>
        <%= f.email_field :email, class: "form-control", required: true %>
        <% if @user.errors[:email].any? %>
          <span class="field-error"><%= @user.errors[:email].first %></span>
        <% end %>
      </div>
      
      <div class="form-group">
        <%= f.label :password, "Password", class: "form-label" %>
        <%= f.password_field :password, class: "form-control", required: true, 
                            placeholder: "Minimum 6 characters" %>
        <% if @user.errors[:password].any? %>
          <span class="field-error"><%= @user.errors[:password].first %></span>
        <% end %>
      </div>
      
      <div class="form-group">
        <%= f.label :password_confirmation, "Confirm Password", class: "form-label" %>
        <%= f.password_field :password_confirmation, class: "form-control", required: true %>
        <% if @user.errors[:password_confirmation].any? %>
          <span class="field-error"><%= @user.errors[:password_confirmation].first %></span>
        <% end %>
      </div>
      
      <div class="form-group">
        <label class="checkbox-label">
          <%= f.check_box :terms_of_service, required: true %>
          I agree to the <a href="#" class="auth-link">Terms of Service</a> and <a href="#" class="auth-link">Privacy Policy</a>
        </label>
        <% if @user.errors[:terms_of_service].any? %>
          <span class="field-error"><%= @user.errors[:terms_of_service].first %></span>
        <% end %>
      </div>
      
      <%= f.submit "Create Account", class: "auth-btn" %>
    <% end %>
    
    <p class="auth-text">
      Already have an account? <%= link_to "Log in", auth_login_form_path, class: "auth-link" %>
    </p>
    
    <p class="auth-text">
      <%= link_to "Back to Home", root_path %>
    </p>
  </div>
</div> 
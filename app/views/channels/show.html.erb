<div class="channel-detail-page">
  <div class="page-header">
    <div class="header-content">
      <div class="channel-icon-large">
        <i class="fas fa-satellite"></i>
      </div>
      <div class="header-text">
        <h1><%= @channel.name %></h1>
        <p class="channel-subtitle"><%= @channel.description || "Trading signals and market analysis" %></p>
        <div class="connection-status">
          <% if @is_connected %>
            <span class="status-badge connected">
              <i class="fas fa-check-circle"></i> Connected
            </span>
          <% else %>
            <span class="status-badge available">
              <i class="fas fa-plus-circle"></i> Available
            </span>
          <% end %>
        </div>
      </div>
    </div>
  </div>

  <!-- Flash messages -->
  <% if notice %>
    <div class="alert alert-success">
      <%= notice %>
    </div>
  <% end %>
  
  <% if alert %>
    <div class="alert alert-danger">
      <%= alert %>
    </div>
  <% end %>

  <div class="channel-content">
    <div class="channel-info-section">
      <h2>Channel Information</h2>
      <div class="info-grid">
        <div class="info-item">
          <span class="info-label">Channel Name</span>
          <span class="info-value"><%= @channel.name %></span>
        </div>
        <div class="info-item">
          <span class="info-label">Discord Channel ID</span>
          <span class="info-value"><%= @channel.discord_channel_id || "Not specified" %></span>
        </div>
        <div class="info-item">
          <span class="info-label">Status</span>
          <span class="info-value">
            <%= @is_connected ? "Connected" : "Available" %>
          </span>
        </div>
        <div class="info-item">
          <span class="info-label">Created</span>
          <span class="info-value"><%= @channel.created_at.strftime("%B %d, %Y") %></span>
        </div>
      </div>
    </div>

    <div class="channel-description-section">
      <h2>About This Channel</h2>
      <div class="description-content">
        <p><%= @channel.description || "This channel provides automated trading signals and market analysis to help you make informed trading decisions." %></p>
        
        <h3>What you'll get:</h3>
        <ul>
          <li>Real-time trading signals</li>
          <li>Market analysis and insights</li>
          <li>Automated trade execution</li>
          <li>Performance tracking</li>
        </ul>
      </div>
    </div>

    <div class="requirements-section">
      <h2>Requirements</h2>
      <div class="requirements-list">
        <div class="requirement-item">
          <div class="requirement-icon">
            <i class="fab fa-discord"></i>
          </div>
          <div class="requirement-content">
            <h4>Discord Membership</h4>
            <p>You must be a member of the Discord server to receive signals from this channel.</p>
          </div>
          <div class="requirement-status">
            <span class="status-pending">Verify Manually</span>
          </div>
        </div>

        <div class="requirement-item">
          <div class="requirement-icon">
            <i class="fas fa-key"></i>
          </div>
          <div class="requirement-content">
            <h4>Binance API Credentials</h4>
            <p>API keys are required for automated trading execution.</p>
          </div>
          <div class="requirement-status">
            <% if current_user.has_valid_binance_credentials? %>
              <span class="status-complete">
                <i class="fas fa-check"></i> Connected
              </span>
            <% else %>
              <span class="status-missing">
                <i class="fas fa-times"></i> Not Setup
              </span>
            <% end %>
          </div>
        </div>

        <div class="requirement-item">
          <div class="requirement-icon">
            <i class="fas fa-crown"></i>
          </div>
          <div class="requirement-content">
            <h4>Active Subscription</h4>
            <p>An active subscription is required to receive trading signals.</p>
          </div>
          <div class="requirement-status">
            <% if current_user.subscription_status == 'active' %>
              <span class="status-complete">
                <i class="fas fa-check"></i> Active
              </span>
            <% else %>
              <span class="status-missing">
                <i class="fas fa-times"></i> Inactive
              </span>
            <% end %>
          </div>
        </div>
      </div>
    </div>

    <div class="actions-section">
      <div class="action-buttons">
        <% if @is_connected %>
          <%= link_to "Disconnect", channel_path(@channel), method: :delete, 
                      class: "btn btn-danger",
                      confirm: "Are you sure you want to disconnect from #{@channel.name}? You will stop receiving signals from this channel." %>
          <span class="action-note">You are currently connected to this channel and receiving signals.</span>
        <% else %>
          <%= link_to "Connect to Channel", channel_path(@channel), method: :post, 
                      class: "btn btn-primary" %>
          <span class="action-note">Connect to start receiving automated trading signals.</span>
        <% end %>
        
        <%= link_to "Back to Channels", channels_path, class: "btn btn-secondary" %>
      </div>

      <% unless current_user.has_valid_binance_credentials? %>
        <div class="setup-prompt">
          <h3>Setup Required</h3>
          <p>To start automated trading, you need to configure your Binance API credentials.</p>
          <%= link_to "Setup API Credentials", api_credentials_path, class: "btn btn-warning" %>
        </div>
      <% end %>
    </div>
  </div>
</div>


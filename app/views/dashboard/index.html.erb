  padding: 20px;
  border-radius: 12px;
  margin-top: 30px;
  text-align: center;
}

.setup-prompt h3 {
  margin: 0 0 10px 0;
}

.setup-prompt p {
  margin: 0 0 15px 0;
}

@media (max-width: 768px) {
  .dashboard-container {
    padding: 15px;
  }
  
  .subscription-banner {
    flex-direction: column;
    text-align: center;
    gap: 15px;
  }
  
  .dashboard-stats {
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
  }
  
  .action-grid {
    grid-template-columns: 1fr;
  }
}
</style>


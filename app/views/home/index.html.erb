<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Tramate - Automated Trading Platform</title>
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
      font-family: Arial, sans-serif;
    }
    
    body {
      background-color: #f4f6f9;
    }
    
    .landing-container {
      max-width: 1200px;
      margin: 0 auto;
      padding: 20px;
    }
    
    .header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 20px 0;
    }
    
    .logo {
      font-size: 32px;
      font-weight: bold;
      color: #3C00D8;
    }
    
    .nav-buttons {
      display: flex;
      gap: 15px;
    }
    
    .btn {
      padding: 12px 25px;
      border-radius: 10px;
      font-weight: bold;
      cursor: pointer;
      text-decoration: none;
      transition: all 0.3s ease;
    }
    
    .btn-primary {
      background-color: #3C00D8;
      color: white;
      border: none;
    }
    
    .btn-secondary {
      background-color: white;
      color: #3C00D8;
      border: 1px solid #3C00D8;
    }
    
    .btn:hover {
      transform: translateY(-3px);
      box-shadow: 0 5px 15px rgba(0, 0, 0, 0.1);
    }
    
    .hero {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 80px 0;
    }
    
    .hero-content {
      max-width: 50%;
    }
    
    .hero-title {
      font-size: 48px;
      font-weight: bold;
      color: #333;
      margin-bottom: 20px;
      line-height: 1.2;
    }
    
    .hero-subtitle {
      font-size: 20px;
      color: #666;
      margin-bottom: 30px;
      line-height: 1.5;
    }
    
    .hero-image {
      width: 45%;
    }
    
    .hero-image img {
      width: 100%;
      border-radius: 10px;
    }
    
    .features {
      padding: 80px 0;
      text-align: center;
    }
    
    .features-title {
      font-size: 36px;
      font-weight: bold;
      color: #333;
      margin-bottom: 50px;
    }
    
    .features-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
      gap: 30px;
    }
    
    .feature-card {
      background-color: white;
      padding: 30px;
      border-radius: 15px;
      box-shadow: 0 5px 15px rgba(0, 0, 0, 0.05);
      text-align: left;
    }
    
    .feature-icon {
      font-size: 36px;
      color: #3C00D8;
      margin-bottom: 15px;
    }
    
    .feature-title {
      font-size: 22px;
      font-weight: bold;
      margin-bottom: 15px;
    }
    
    .feature-desc {
      color: #666;
      line-height: 1.6;
    }
    
    .pricing {
      padding: 80px 0;
      text-align: center;
    }
    
    .pricing-title {
      font-size: 36px;
      font-weight: bold;
      color: #333;
      margin-bottom: 50px;
    }
    
    .pricing-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
      gap: 30px;
    }
    
    .pricing-card {
      background-color: white;
      padding: 30px;
      border-radius: 15px;
      box-shadow: 0 5px 15px rgba(0, 0, 0, 0.05);
      text-align: left;
      position: relative;
      overflow: hidden;
    }
    
    .pricing-tag {
      position: absolute;
      top: 0;
      right: 0;
      background-color: #16C79A;
      color: white;
      padding: 5px 15px;
      font-weight: bold;
      border-bottom-left-radius: 10px;
    }
    
    .pricing-header {
      margin-bottom: 20px;
    }
    
    .pricing-name {
      font-size: 22px;
      font-weight: bold;
    }
    
    .pricing-price {
      font-size: 36px;
      font-weight: bold;
    }
    
    .pricing-period {
      color: #666;
    }
    
    .pricing-features {
      list-style: none;
      margin-bottom: 25px;
    }
    
    .pricing-features li {
      margin: 10px 0;
      display: flex;
      align-items: center;
    }
    
    .pricing-features li:before {
      content: "✓";
      color: #16C79A;
      font-weight: bold;
      margin-right: 10px;
    }
    
    .pricing-btn {
      width: 100%;
      text-align: center;
    }
    
    .footer {
      background-color: #333;
      color: white;
      padding: 50px 0;
    }
    
    .footer-container {
      max-width: 1200px;
      margin: 0 auto;
      padding: 0 20px;
      display: flex;
      justify-content: space-between;
      flex-wrap: wrap;
    }
    
    .footer-section {
      margin-bottom: 30px;
      min-width: 200px;
    }
    
    .footer-title {
      font-size: 20px;
      font-weight: bold;
      margin-bottom: 20px;
    }
    
    .footer-links {
      list-style: none;
    }
    
    .footer-links li {
      margin: 10px 0;
    }
    
    .footer-links a {
      color: #ccc;
      text-decoration: none;
      transition: color 0.3s;
    }
    
    .footer-links a:hover {
      color: white;
    }
    
    .copyright {
      text-align: center;
      padding: 20px 0;
      color: #999;
      border-top: 1px solid #444;
      margin-top: 30px;
      width: 100%;
    }
    
    /* Responsive */
    @media (max-width: 768px) {
      .hero {
        flex-direction: column;
        text-align: center;
      }
      
      .hero-content {
        max-width: 100%;
        margin-bottom: 40px;
      }
      
      .hero-image {
        width: 100%;
      }
    }
  </style>
</head>
<body>
  <div class="landing-container">
    <!-- Header -->
    <header class="header">
      <div class="logo">Tramate.</div>
      <div class="nav-buttons">
        <%= link_to "Login", auth_login_form_path, class: "btn btn-secondary" %>
        <%= link_to "Register", auth_register_form_path, class: "btn btn-primary" %>
      </div>
    </header>

    <!-- Hero Section -->
    <section class="hero">
      <div class="hero-content">
        <h1 class="hero-title">Automated Trading Made Simple</h1>
        <p class="hero-subtitle">Connect your preferred exchanges and let our platform handle your trades. Maximize your profits with our advanced algorithms and expert signals.</p>
        <%= link_to "Start Trading Now", auth_register_form_path, class: "btn btn-primary" %>
      </div>
      <div class="hero-image">
        <img src="https://via.placeholder.com/500x350" alt="Trading Dashboard">
      </div>
    </section>

    <!-- Features Section -->
    <section class="features">
      <h2 class="features-title">Why Choose Tramate</h2>
      <div class="features-grid">
        <div class="feature-card">
          <div class="feature-icon">🔒</div>
          <h3 class="feature-title">Secure API Integration</h3>
          <p class="feature-desc">Connect securely to your favorite exchanges without compromising your funds. Our platform uses read-only API keys.</p>
        </div>
        <div class="feature-card">
          <div class="feature-icon">📊</div>
          <h3 class="feature-title">Expert Trading Signals</h3>
          <p class="feature-desc">Access verified trading signals from professional traders and execute them automatically.</p>
        </div>
        <div class="feature-card">
          <div class="feature-icon">⚙️</div>
          <h3 class="feature-title">Fully Automated</h3>
          <p class="feature-desc">Set up once and let the platform handle the rest. Save time and eliminate emotional trading decisions.</p>
        </div>
      </div>
    </section>

    <!-- Pricing Section -->
    <section class="pricing">
      <h2 class="pricing-title">Choose Your Plan</h2>
      <div class="pricing-grid">
        <div class="pricing-card">
          <div class="pricing-header">
            <h3 class="pricing-name">Starter</h3>
            <div class="pricing-price">Free</div>
            <div class="pricing-period">Forever</div>
          </div>
          <ul class="pricing-features">
            <li>1 Trade per day</li>
            <li>Basic signal access</li>
            <li>Manual trade execution</li>
            <li>Email support</li>
          </ul>
          <%= link_to "Get Started", auth_register_form_path, class: "btn btn-secondary pricing-btn" %>
        </div>
        
        <div class="pricing-card">
          <div class="pricing-tag">Popular</div>
          <div class="pricing-header">
            <h3 class="pricing-name">Intermediate</h3>
            <div class="pricing-price">$5<span class="pricing-period">/month</span></div>
          </div>
          <ul class="pricing-features">
            <li>20 Trades per month</li>
            <li>Premium signal access</li>
            <li>Automated trade execution</li>
            <li>Priority email support</li>
          </ul>
          <%= link_to "Choose Plan", auth_register_form_path, class: "btn btn-primary pricing-btn" %>
        </div>
        
        <div class="pricing-card">
          <div class="pricing-header">
            <h3 class="pricing-name">Premium</h3>
            <div class="pricing-price">$15<span class="pricing-period">/month</span></div>
          </div>
          <ul class="pricing-features">
            <li>Unlimited trades</li>
            <li>All signal channels</li>
            <li>Advanced automation</li>
            <li>Priority support</li>
          </ul>
          <%= link_to "Choose Plan", auth_register_form_path, class: "btn btn-secondary pricing-btn" %>
        </div>
      </div>
    </section>
  </div>

  <!-- Footer -->
  <footer class="footer">
    <div class="footer-container">
      <div class="footer-section">
        <h3 class="footer-title">Tramate</h3>
        <p>The future of automated trading.</p>
      </div>
      
      <div class="footer-section">
        <h3 class="footer-title">Quick Links</h3>
        <ul class="footer-links">
          <li><a href="#">Home</a></li>
          <li><a href="#">Features</a></li>
          <li><a href="#">Pricing</a></li>
          <li><a href="#">Contact</a></li>
        </ul>
      </div>
      
      <div class="footer-section">
        <h3 class="footer-title">Legal</h3>
        <ul class="footer-links">
          <li><a href="#">Privacy Policy</a></li>
          <li><a href="#">Terms of Service</a></li>
        </ul>
      </div>
      
      <div class="footer-section">
        <h3 class="footer-title">Support</h3>
        <ul class="footer-links">
          <li><a href="#">Help Center</a></li>
          <li><a href="#">Contact Us</a></li>
        </ul>
      </div>
      
      <div class="copyright">
        &copy; <%= Date.current.year %> Tramate. All rights reserved.
      </div>
    </div>
  </footer>
</body>
</html>
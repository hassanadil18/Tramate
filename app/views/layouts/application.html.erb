<!DOCTYPE html>
<html>
  <head>
    <title>Tramate</title>
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= stylesheet_link_tag "application" %>
    <%= javascript_include_tag "application" %>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" integrity="sha512-DTOQO9RWCH3ppGqcWaEA1BIZOC6xxalwEsw9c2QQeAIftl+Vegovlnee1c9QX4TctnWMn13TZye+giMm8e2LwA==" crossorigin="anonymous" referrerpolicy="no-referrer" />
  </head>

  <body class="tramate-body">
    <header class="tramate-header">
      <div class="container">
        <div class="header-content">
          <div class="logo">
            <%= image_tag "tramateLogog.png", alt: "Tramate Logo", class: "logo-image" %>
          </div>
          <button class="mobile-menu-toggle" aria-label="Toggle menu">
            <span class="hamburger"></span>
          </button>
          <nav class="main-nav">
            <ul>
              <li><%= link_to "Home", root_path %></li>
              <li><%= link_to "How it works", "#how-it-works" %></li>
              <li><%= link_to "Memberships", "#memberships" %></li>
              <li><%= link_to "About", "#about" %></li>
              <li><%= link_to "Contact", "#contact" %></li>
              <li class="login-btn"><%= link_to "Login", auth_login_form_path %></li>
              <li class="signup-btn"><%= link_to "Sign Up", auth_register_form_path %></li>
            </ul>
          </nav>
        </div>
      </div>
    </header>

    <% if flash[:notice] %>
      <div class="flash-message notice">
        <div class="container">
          <p><%= flash[:notice] %></p>
          <button class="close-flash">&times;</button>
        </div>
      </div>
    <% end %>
    
    <% if flash[:alert] %>
      <div class="flash-message alert">
        <div class="container">
          <p><%= flash[:alert] %></p>
          <button class="close-flash">&times;</button>
        </div>
      </div>
    <% end %>

    <main class="tramate-content">
      <%= yield %>
      
      <div class="scroll-to-top">
        <i class="fa-solid fa-arrow-up"></i>
      </div>
    </main>

    <footer class="tramate-footer">
      <div class="footer-main">
        <div class="container">
          <div class="footer-columns">
            <div class="footer-col company-info">
              <div class="footer-brand">
                <%= image_tag "tramateLogog.png", alt: "Tramate Logo", class: "footer-logo-image", width: "180" %>
              </div>
              <p class="disclaimer">
                Tramate is official trademark of Tramate.Inc. Tramate has registered LLC to operate in United States. Tramate cannot be hold accountable for any kind of mistreat from channel's misbehavior. Errors and omissions on behalf of Tramate can be challenged with our support
              </p>
              <div class="social-icons">
                <a href="#" class="social-icon"><i class="fa-brands fa-facebook-f"></i></a>
                <a href="#" class="social-icon"><i class="fa-brands fa-twitter"></i></a>
                <a href="#" class="social-icon"><i class="fa-brands fa-instagram"></i></a>
                <a href="#" class="social-icon"><i class="fa-brands fa-linkedin-in"></i></a>
              </div>
            </div>
            <div class="footer-col">
              <h3>Support</h3>
              <ul>
                <li><a href="#">Support</a></li>
                <li><a href="#">Community</a></li>
                <li><a href="#">About us</a></li>
              </ul>
            </div>
            <div class="footer-col">
              <h3>Resources</h3>
              <ul>
                <li><a href="#">Contact</a></li>
                <li><a href="#">Memberships</a></li>
                <li><a href="#">Documentation</a></li>
              </ul>
            </div>
          </div>
          <div class="footer-bottom">
            <div class="footer-links">
              <%= link_to "Privacy Policy", privacy_policy_path, class: "policy-link" %>
              <%= link_to "Terms & Conditions", terms_and_conditions_path, class: "policy-link" %>
            </div>
          </div>
        </div>
      </div>
    </footer>
  </body>
</html>
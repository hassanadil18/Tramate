<div class="registration-step">
  <div class="registration-container">
    <div class="step-header">
      <div class="step-progress">
        <div class="progress-bar">
          <div class="progress-fill" style="width: 50%;"></div>
        </div>
        <div class="step-indicators">
          <div class="step-indicator completed">1</div>
          <div class="step-indicator active">2</div>
          <div class="step-indicator">3</div>
          <div class="step-indicator">4</div>
        </div>
        <div class="step-labels">
          <span class="completed">Account</span>
          <span class="active">Discord</span>
          <span>API Setup</span>
          <span>Subscription</span>
        </div>
      </div>
      
      <div class="step-content-header">
        <h1>Discord Verification & Channel Selection</h1>
        <p class="subtitle">Choose your signal channel and verify your Discord membership</p>
      </div>
    </div>

    <!-- Flash messages -->
    <% if notice %>
      <div class="alert alert-success">
        <%= notice %>
      </div>
    <% end %>
    
    <% if alert %>
      <div class="alert alert-danger">
        <%= alert %>
      </div>
    <% end %>

    <div class="step-content">
      <%= form_with url: registration_step2_path, method: :post, local: true, class: "registration-form" do |form| %>
        
        <!-- Channel Selection -->
        <div class="form-section">
          <h2>Choose Your Signal Channel</h2>
          <p>Select the trading signal channel you want to connect to. You must be a member of the corresponding Discord server.</p>
          
          <div class="channels-selection">
            <% @channels.each do |channel| %>
              <div class="channel-option">
                <input type="radio" 
                       name="channel_id" 
                       value="<%= channel.id %>" 
                       id="channel_<%= channel.id %>"
                       <%= 'checked' if @selected_channel_id&.to_i == channel.id %>
                       required>
                <label for="channel_<%= channel.id %>" class="channel-card">
                  <div class="channel-icon">
                    <i class="fas fa-satellite"></i>
                  </div>
                  <div class="channel-info">
                    <h3><%= channel.name %></h3>
                    <p class="channel-description">
                      <%= channel.description || "Premium trading signals and market analysis" %>
                    </p>
                    <div class="channel-meta">
                      <span class="discord-id">Discord ID: <%= channel.discord_channel_id || "N/A" %></span>
                      <% if channel.discord_invite_link.present? %>
                        <a href="<%= channel.discord_invite_link %>" target="_blank" class="discord-link">
                          <i class="fab fa-discord"></i> Join Server
                        </a>
                      <% end %>
                    </div>
                  </div>
                </label>
              </div>
            <% end %>
          </div>
        </div>

        <!-- Discord Verification -->
        <div class="form-section">
          <h2>Discord Username Verification</h2>
          <p>Enter your Discord username to verify that you're a member of the selected channel's Discord server.</p>
          
          <div class="form-group">
            <label for="discord_username">Discord Username</label>
            <div class="input-group">
              <div class="input-icon">
                <i class="fab fa-discord"></i>
              </div>
              <input type="text" 
                     name="discord_username" 
                     id="discord_username" 
                     class="form-control" 
                     placeholder="username#1234" 
                     value="<%= @discord_username %>"
                     required
                     autocomplete="off">
            </div>
            <small class="form-text">
              Enter your complete Discord username including the # and numbers (e.g., JohnDoe#1234)
            </small>
          </div>

          <div class="verification-info">
            <div class="info-card">
              <div class="info-icon">
                <i class="fas fa-info-circle"></i>
              </div>
              <div class="info-content">
                <h4>How verification works</h4>
                <ul>
                  <li>We'll check if your Discord username is a member of the selected channel's server</li>
                  <li>You must have joined the Discord server before attempting verification</li>
                  <li>If verification fails, you'll be provided with an invite link</li>
                </ul>
              </div>
            </div>
          </div>
        </div>

        <!-- Help Section -->
        <div class="help-section">
          <h3>Need Help?</h3>
          
          <div class="help-grid">
            <div class="help-card">
              <h4><i class="fas fa-user-circle"></i> Finding Your Discord Username</h4>
              <div class="steps">
                <div class="step">
                  <span class="step-number">1</span>
                  <span class="step-text">Open Discord and click on your profile picture</span>
                </div>
                <div class="step">
                  <span class="step-number">2</span>
                  <span class="step-text">Your username will be displayed (e.g., username#1234)</span>
                </div>
                <div class="step">
                  <span class="step-number">3</span>
                  <span class="step-text">Copy it exactly including the # and numbers</span>
                </div>
              </div>
            </div>

            <div class="help-card">
              <h4><i class="fas fa-question-circle"></i> Not a Discord Member?</h4>
              <p>You need to join the Discord server for your selected channel first. Use the "Join Server" links above or contact support for invite links.</p>
            </div>
          </div>
        </div>

        <!-- Form Actions -->
        <div class="form-actions">
          <%= link_to "Back", registration_step1_path, class: "btn btn-secondary" %>
          <button type="submit" class="btn btn-primary">
            <i class="fas fa-shield-alt"></i>
            Verify & Continue
          </button>
        </div>
      <% end %>
    </div>
  </div>
</div>


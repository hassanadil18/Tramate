<div class="registration-container">
  <div class="registration-sidebar">
    <div class="logo-wrapper">
      <h2 class="logo">Tramate.</h2>
    </div>
    
    <div class="steps-container">
      <div class="step-item completed">
        <div class="step-number"><i class="fas fa-check"></i></div>
        <div class="step-label">Create Account</div>
      </div>
      <div class="step-item completed">
        <div class="step-number"><i class="fas fa-check"></i></div>
        <div class="step-label">Connect Discord</div>
      </div>
      <div class="step-item completed">
        <div class="step-number"><i class="fas fa-check"></i></div>
        <div class="step-label">API Setup</div>
      </div>
      <div class="step-item active">
        <div class="step-number">4</div>
        <div class="step-label">Subscription</div>
      </div>
    </div>
    
    <div class="registration-info">
      <h3>Choose your plan</h3>
      <p>Select the subscription plan that best fits your trading needs. You can upgrade or downgrade at any time.</p>
    </div>
  </div>
  
  <div class="registration-form">
    <h2>Select Your Trading Plan</h2>
    <p class="form-subtitle">Choose the subscription that matches your trading goals</p>
    
    <% if flash[:alert] %>
      <div class="alert alert-danger"><%= flash[:alert] %></div>
    <% end %>
    
    <%= form_with url: registration_subscription_path, method: :post, id: "subscriptionForm" do |f| %>
      <div class="subscription-plans">
        <% @subscriptions.each do |subscription| %>
          <div class="plan-card <%= subscription.name.downcase %>">
            <div class="plan-header">
              <h3><%= subscription.name %></h3>
              <div class="plan-price">
                <% if subscription.price.zero? %>
                  <span class="price">FREE</span>
                <% else %>
                  <span class="price">$<%= subscription.price %></span>
                  <span class="period">/month</span>
                <% end %>
              </div>
            </div>
            
            <div class="plan-features">
              <p class="plan-description"><%= subscription.description %></p>
              <ul>
                <% if subscription.trade_limit.nil? %>
                  <li><strong>Unlimited</strong> trades</li>
                <% else %>
                  <li><strong><%= subscription.trade_limit %></strong> trades per month</li>
                <% end %>
                <li>Real-time signal execution</li>
                <li>Access to trading dashboard</li>
                <% if subscription.name == 'Premium' %>
                  <li>Priority support</li>
                  <li>Advanced analytics</li>
                <% end %>
              </ul>
            </div>
            
            <div class="plan-select">
              <label class="plan-radio">
                <%= radio_button_tag 'subscription_id', subscription.id, false, required: true %>
                <span class="checkmark"></span>
                Select <%= subscription.name %>
              </label>
            </div>
          </div>
        <% end %>
      </div>
      
      <div class="button-group">
        <a href="<%= registration_step3_path %>" class="btn btn-outline">Back</a>
        <button type="submit" class="btn btn-primary">Complete Registration</button>
      </div>
    <% end %>
  </div>
</div>

<style>
  body {
    margin: 0;
    padding: 0;
    font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    background-color: #f8f9fa;
  }
  
  .registration-container {
    display: flex;
    min-height: 100vh;
  }
  
  .registration-sidebar {
    width: 320px;
    background-color: #00ADB5;
    color: white;
    padding: 40px 30px;
    display: flex;
    flex-direction: column;
  }
  
  .logo-wrapper {
    margin-bottom: 60px;
  }
  
  .logo {
    font-size: 28px;
    font-weight: 700;
  }
  
  .steps-container {
    margin-bottom: 40px;
  }
  
  .step-item {
    display: flex;
    align-items: center;
    margin-bottom: 25px;
    opacity: 0.7;
  }
  
  .step-item.active {
    opacity: 1;
  }
  
  .step-item.completed {
    opacity: 1;
  }
  
  .step-number {
    width: 30px;
    height: 30px;
    border-radius: 50%;
    background-color: rgba(255, 255, 255, 0.2);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-right: 15px;
    font-weight: 600;
  }
  
  .step-item.active .step-number {
    background-color: white;
    color: #00ADB5;
  }
  
  .step-item.completed .step-number {
    background-color: white;
    color: #00ADB5;
  }
  
  .step-label {
    font-size: 16px;
    font-weight: 500;
  }
  
  .registration-info {
    margin-top: auto;
    background-color: rgba(255, 255, 255, 0.1);
    padding: 20px;
    border-radius: 10px;
  }
  
  .registration-info h3 {
    font-size: 18px;
    margin-top: 0;
    margin-bottom: 10px;
  }
  
  .registration-info p {
    font-size: 14px;
    line-height: 1.5;
    opacity: 0.9;
  }
  
  .registration-form {
    flex: 1;
    padding: 40px;
    overflow-y: auto;
  }
  
  h2 {
    margin-top: 0;
    font-size: 28px;
    color: #333;
    margin-bottom: 10px;
  }
  
  .form-subtitle {
    color: #666;
    margin-bottom: 30px;
  }
  
  .subscription-plans {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 20px;
    margin-bottom: 30px;
  }
  
  .plan-card {
    border-radius: 10px;
    box-shadow: 0 5px 15px rgba(0, 0, 0, 0.08);
    overflow: hidden;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    background-color: white;
  }
  
  .plan-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 10px 20px rgba(0, 0, 0, 0.12);
  }
  
  .plan-card.starter {
    border-top: 5px solid #00ADB5;
  }
  
  .plan-card.intermediate {
    border-top: 5px solid #FF5722;
  }
  
  .plan-card.premium {
    border-top: 5px solid #673AB7;
  }
  
  .plan-header {
    padding: 20px;
    text-align: center;
    border-bottom: 1px solid #f1f1f1;
  }
  
  .plan-header h3 {
    margin: 0;
    font-size: 20px;
    font-weight: 600;
  }
  
  .plan-price {
    margin-top: 10px;
  }
  
  .plan-price .price {
    font-size: 28px;
    font-weight: 700;
  }
  
  .plan-price .period {
    font-size: 14px;
    color: #888;
  }
  
  .plan-features {
    padding: 20px;
  }
  
  .plan-description {
    margin-bottom: 15px;
    color: #666;
    font-size: 14px;
  }
  
  .plan-features ul {
    list-style-type: none;
    padding: 0;
    margin: 0;
  }
  
  .plan-features li {
    padding: 8px 0;
    position: relative;
    padding-left: 25px;
    font-size: 14px;
  }
  
  .plan-features li:before {
    content: '✓';
    color: #00ADB5;
    position: absolute;
    left: 0;
    font-weight: bold;
  }
  
  .plan-select {
    padding: 15px 20px;
    border-top: 1px solid #f1f1f1;
  }
  
  .plan-radio {
    display: flex;
    align-items: center;
    cursor: pointer;
    user-select: none;
    position: relative;
  }
  
  .plan-radio input {
    position: absolute;
    opacity: 0;
    cursor: pointer;
    height: 0;
    width: 0;
  }
  
  .checkmark {
    position: relative;
    display: inline-block;
    height: 20px;
    width: 20px;
    background-color: #f1f1f1;
    border-radius: 50%;
    margin-right: 10px;
  }
  
  .plan-radio:hover .checkmark {
    background-color: #e1e1e1;
  }
  
  .plan-radio input:checked ~ .checkmark {
    background-color: #00ADB5;
  }
  
  .checkmark:after {
    content: "";
    position: absolute;
    display: none;
  }
  
  .plan-radio input:checked ~ .checkmark:after {
    display: block;
  }
  
  .plan-radio .checkmark:after {
    top: 6px;
    left: 6px;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: white;
  }
  
  .button-group {
    display: flex;
    justify-content: space-between;
    margin-top: 30px;
  }
  
  .btn {
    padding: 14px 20px;
    border-radius: 6px;
    font-size: 16px;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.2s;
  }
  
  .btn-primary {
    background-color: #00ADB5;
    color: white;
    border: none;
  }
  
  .btn-primary:hover {
    background-color: #008e96;
  }
  
  .btn-outline {
    background-color: transparent;
    border: 1px solid #ddd;
    color: #666;
    text-decoration: none;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  
  .btn-outline:hover {
    border-color: #ccc;
    background-color: #f9f9f9;
  }
  
  .alert {
    padding: 15px;
    border-radius: 6px;
    margin-bottom: 20px;
  }
  
  .alert-danger {
    background-color: #f8d7da;
    color: #721c24;
    border: 1px solid #f5c6cb;
  }
  
  @media (max-width: 992px) {
    .registration-container {
      flex-direction: column;
    }
    
    .registration-sidebar {
      width: 100%;
      padding: 30px 20px;
    }
    
    .registration-form {
      padding: 30px 20px;
    }
    
    .button-group {
      flex-direction: column;
    }
    
    .btn {
      width: 100%;
      margin-bottom: 10px;
    }
    
    .subscription-plans {
      grid-template-columns: 1fr;
    }
  }
</style> 
<div class="payment-container">
  <div class="payment-content">
    <h1 class="payment-title">Complete Your Subscription</h1>
    
    <div class="plan-summary">
      <h2><%= @subscription.name %> Plan</h2>
      <div class="plan-details">
        <div class="plan-price">
          <% if @subscription.price.zero? %>
            <span class="price">FREE</span>
          <% else %>
            <span class="price">$<%= @subscription.price %></span>
            <span class="period">/month</span>
          <% end %>
        </div>
        <div class="plan-features">
          <% if @subscription.trade_limit.nil? %>
            <p><strong>Unlimited</strong> trades</p>
          <% else %>
            <p><strong><%= @subscription.trade_limit %></strong> trades per month</p>
          <% end %>
        </div>
      </div>
    </div>
    
    <% if @subscription.price.zero? %>
      <div class="payment-success">
        <p>Your free plan is ready to be activated!</p>
        <%= button_to "Activate Free Plan", subscription_path(@subscription), method: :post, class: "btn btn-primary btn-activate" %>
      </div>
    <% else %>
      <div class="payment-form">
        <h3>Payment Details</h3>
        
        <% if @payment_error %>
          <div class="payment-error-notice">
            <p><i class="fas fa-exclamation-triangle"></i> <%= @payment_error %></p>
          </div>
        <% end %>
        
        <div class="checkout-widget">
          <% if @payment_data && @public_key %>
            <!-- Checkout.com Payment Form -->
            <div class="checkout-payment-form">
              <div id="payment-form">
                <div class="form-row">
                  <label for="card-number">Card Number</label>
                  <div id="card-number" class="card-frame"></div>
                </div>
                <div class="form-row">
                  <div class="form-col">
                    <label for="expiry-date">Expiry Date</label>
                    <div id="expiry-date" class="card-frame"></div>
                  </div>
                  <div class="form-col">
                    <label for="cvv">CVV</label>
                    <div id="cvv" class="card-frame"></div>
                  </div>
                </div>
                <div class="form-row">
                  <label for="cardholder-name">Cardholder Name</label>
                  <input type="text" id="cardholder-name" placeholder="<%= current_user.full_name %>" value="<%= current_user.full_name %>">
                </div>
                <button type="button" id="pay-button" class="btn btn-primary btn-pay" disabled>
                  Pay $<%= @subscription.price %>
                </button>
              </div>
              <div id="payment-errors" class="payment-errors"></div>
            </div>
            
            <script src="https://cdn.checkout.com/js/framesv2.min.js"></script>
            <script>
              document.addEventListener('DOMContentLoaded', function() {
                console.log('Initializing Checkout.com Frames...');
                
                Frames.init({
                  publicKey: '<%= @public_key %>',
                  localization: 'EN-GB',
                  style: {
                    base: {
                      fontSize: '16px',
                      fontFamily: 'Arial, sans-serif',
                      color: '#333'
                    },
                    invalid: {
                      color: '#dc3545'
                    },
                    placeholder: {
                      base: {
                        color: '#999'
                      }
                    }
                  },
                  cardholder: {
                    name: '<%= current_user.full_name %>',
                    billingAddress: {
                      addressLine1: '',
                      city: '',
                      state: '',
                      zip: '',
                      country: 'US'
                    }
                  }
                });
                
                console.log('Frames initialized');
                
                Frames.addEventHandler(
                  Frames.Events.FRAME_READY,
                  function(event) {
                    console.log('Frame ready:', event.element);
                  }
                );
                
                Frames.addEventHandler(
                  Frames.Events.CARD_VALIDATION_CHANGED,
                  function(event) {
                    console.log('Card validation changed:', event);
                    var payButton = document.getElementById('pay-button');
                    if (payButton) {
                      payButton.disabled = !event.isValid;
                      if (event.isValid) {
                        payButton.style.opacity = '1';
                        payButton.style.cursor = 'pointer';
                      } else {
                        payButton.style.opacity = '0.6';
                        payButton.style.cursor = 'not-allowed';
                      }
                    }
                  }
                );
                
                Frames.addEventHandler(
                  Frames.Events.PAYMENT_METHOD_CHANGED,
                  function(event) {
                    console.log('Payment method changed:', event);
                  }
                );
                
                document.getElementById('pay-button').addEventListener('click', function() {
                  console.log('Pay button clicked');
                  var payButton = this;
                  payButton.disabled = true;
                  payButton.textContent = 'Processing...';
                  
                  Frames.submitCard()
                    .then(function(data) {
                      console.log('Card submitted successfully:', data);
                      // For now, simulate success since we don't have proper secret key
                      // In production, this would send to the real payment endpoint
                      fetch('<%= subscriptions_path %>', {
                        method: 'POST',
                        headers: {
                          'Content-Type': 'application/x-www-form-urlencoded',
                          'X-CSRF-Token': '<%= form_authenticity_token %>'
                        },
                        body: new URLSearchParams({
                          subscription_id: '<%= @subscription.id %>',
                          status: 'success',
                          payment_id: 'checkout_' + data.token,
                          payment_method: 'checkout_com'
                        })
                      })
                      .then(response => {
                        if (response.redirected) {
                          window.location.href = response.url;
                        } else {
                          return response.text();
                        }
                      })
                      .then(data => {
                        if (data) {
                          document.getElementById('payment-errors').innerHTML = 'Payment completed successfully!';
                          setTimeout(() => {
                            window.location.href = '<%= success_subscription_path(@subscription) %>';
                          }, 1000);
                        }
                      })
                      .catch(error => {
                        console.error('Payment error:', error);
                        document.getElementById('payment-errors').innerHTML = 'Payment failed. Please try again.';
                        payButton.disabled = false;
                        payButton.textContent = 'Pay $<%= @subscription.price %>';
                      });
                    })
                    .catch(function(error) {
                      console.error('Card submission error:', error);
                      document.getElementById('payment-errors').innerHTML = error.message;
                      payButton.disabled = false;
                      payButton.textContent = 'Pay $<%= @subscription.price %>';
                    });
                });
              });
            </script>
          <% else %>
            <!-- Fallback payment form -->
            <div class="manual-payment-form">
              <h4>Complete Your Payment</h4>
              <p>To complete your subscription to the <strong><%= @subscription.name %></strong> plan, please contact our support team.</p>
              
              <div class="payment-options">
                <div class="payment-option">
                  <h5><i class="fas fa-credit-card"></i> Credit Card Payment</h5>
                  <p>Amount: <strong>$<%= @subscription.price %></strong></p>
                  <p>Please contact our support team at <a href="mailto:support@tramate.com">support@tramate.com</a></p>
                </div>
              </div>
              
              <div class="payment-actions">
                <%= link_to "← Back to Plans", subscriptions_path, class: "btn btn-secondary" %>
              </div>
            </div>
          <% end %>
        </div>
        
        <div class="payment-notes">
          <p><i class="fas fa-lock"></i> Your payment information is secure and encrypted.</p>
          <p>You will be charged $<%= @subscription.price %> for a 1-month subscription.</p>
        </div>
      </div>
    <% end %>
  </div>
</div>


#!/bin/bash -e

# ================================================================================
# TRAMATE PLATFORM - DOCKER ENTRYPOINT
# ================================================================================
# Production-ready entrypoint script with enhanced error handling and monitoring
# ================================================================================

set -e

# Color codes for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

# Logging function
log() {
    echo -e "${BLUE}[$(date '+%Y-%m-%d %H:%M:%S')] $1${NC}"
}

error() {
    echo -e "${RED}[$(date '+%Y-%m-%d %H:%M:%S')] ERROR: $1${NC}" >&2
}

warn() {
    echo -e "${YELLOW}[$(date '+%Y-%m-%d %H:%M:%S')] WARNING: $1${NC}"
}

success() {
    echo -e "${GREEN}[$(date '+%Y-%m-%d %H:%M:%S')] SUCCESS: $1${NC}"
}

# Enable jemalloc for reduced memory usage and latency
log "Configuring memory allocator..."
if [ -z "${LD_PRELOAD+x}" ]; then
    LD_PRELOAD=$(find /usr/lib -name libjemalloc.so.2 -print -quit)
    export LD_PRELOAD
    log "jemalloc enabled: $LD_PRELOAD"
fi

# Set production optimizations
export RUBY_GC_HEAP_INIT_SLOTS=10000
export RUBY_GC_HEAP_FREE_SLOTS=10000
export RUBY_GC_HEAP_GROWTH_FACTOR=1.1
export RUBY_GC_HEAP_GROWTH_MAX_SLOTS=10000

# Validate environment variables
log "Validating environment configuration..."
required_vars=("RAILS_MASTER_KEY")
for var in "${required_vars[@]}"; do
    if [ -z "${!var}" ]; then
        error "Required environment variable $var is not set"
        exit 1
    fi
done

# Check database connection
check_database() {
    log "Checking database connectivity..."
    local max_attempts=30
    local attempt=1
    
    while [ $attempt -le $max_attempts ]; do
        if ./bin/rails runner "ActiveRecord::Base.connection.execute('SELECT 1')" >/dev/null 2>&1; then
            success "Database connection established"
            return 0
        else
            warn "Database connection attempt $attempt/$max_attempts failed"
            sleep 2
            attempt=$((attempt + 1))
        fi
    done
    
    error "Failed to connect to database after $max_attempts attempts"
    exit 1
}

# Database preparation for Rails server
prepare_database() {
    log "Preparing database..."
    
    # Check if we need to run migrations
    if ./bin/rails runner "ActiveRecord::Base.connection.migration_context.needs_migration?" 2>/dev/null | grep -q "true"; then
        log "Running database migrations..."
        ./bin/rails db:migrate
        success "Database migrations completed"
    else
        log "Database is up to date"
    fi
    
    # Precompile assets if needed in production
    if [ "$RAILS_ENV" = "production" ] && [ ! -f "public/assets/.sprockets-manifest*.json" ]; then
        log "Precompiling assets..."
        ./bin/rails assets:precompile
        success "Assets precompiled"
    fi
}

# Signal handling for graceful shutdown
graceful_shutdown() {
    log "Received shutdown signal, performing graceful shutdown..."
    
    # Send TERM signal to Rails server if running
    if [ ! -z "$RAILS_PID" ]; then
        kill -TERM "$RAILS_PID" 2>/dev/null || true
        wait "$RAILS_PID" 2>/dev/null || true
    fi
    
    success "Graceful shutdown completed"
    exit 0
}

# Set up signal handlers
trap graceful_shutdown TERM INT

# Main execution logic
log "Starting Tramate Platform Docker container..."
log "Environment: $RAILS_ENV"
log "Ruby version: $(ruby -v)"
log "Rails version: $(./bin/rails version)"

# If running the rails server, perform additional setup
if [ "${@: -2:1}" == "./bin/rails" ] && [ "${@: -1:1}" == "server" ]; then
    log "Preparing Rails application server..."
    
    # Check database connectivity
    check_database
    
    # Prepare database and assets
    prepare_database
    
    # Validate critical configurations
    log "Validating application configuration..."
    ./bin/rails runner "
        begin
          Rails.application.config_for(:database)
          puts 'Database configuration: OK'
          
          if defined?(ActionMailer)
            puts 'ActionMailer configuration: OK'
          end
          
          puts 'Application configuration validation completed'
        rescue => e
          puts 'Configuration error: ' + e.message
          exit 1
        end
    "
    
    success "Rails application ready to start"
    
    # Start Rails server in background to capture PID for graceful shutdown
    log "Starting Rails server on port 3000..."
    exec "$@" &
    RAILS_PID=$!
    
    # Wait for the Rails process
    wait "$RAILS_PID"
else
    # For other commands, just execute them directly
    log "Executing command: $*"
    exec "$@"
fi
